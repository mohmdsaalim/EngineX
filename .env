# Postgres
POSTGRES_DSN=postgres://engine_user:engine_pass@localhost:5432/engine_db?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKER=localhost:9092

# JWT
