JWT_REFRESH_TTL=168h

# Service Ports
GATEWAY_PORT=:8080
AUTH_GRPC_PORT=:9091
RISK_GRPC_PORT=:9092
ENGINE_GRPC_PORT=:9093
EXECUTOR_GRPC_PORT=:9094
WSHUB_PORT=:8081